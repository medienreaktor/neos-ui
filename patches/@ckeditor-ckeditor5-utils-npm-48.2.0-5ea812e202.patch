         // Avoid blurs originating from external FTs when the focus still remains in one of the #elements.
         if (isAnyElementFocused) {
             return;
@@ -5730,9 +5740,15 @@ function isExternalViewSubtreeFocused(subTreeRoot, view) {
     return !!view.focusTracker.externalViews.find((view)=>isFocusedView(subTreeRoot, view));
 }
 function isFocusedView(subTreeRoot, view) {
+    /**
+     * Neos patch, we cannot access "document" as this will always be the host frame.
+     * If ckeditor is used in the guest iframe we need to use their document.
+     * -> this patch is not as important as the blur() patch above, we could not find any side effects if this is not enabled, but better have it right.
