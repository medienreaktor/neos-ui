/**
* Overwriting CKEditor 5 styles for the general rendering in the Neos UI
*/

/* hides buggy powered-by logo (credits on https://www.neos.io via "Editor Tools") */
.ck-powered-by-balloon {
    display: none !important;
}

/* hides bar below neos ui */
.ck-aria-live-announcer {
    display: none !important;
}

/* hides ck-default grey border for active editable */
.ck-focused {
    border: none!important;
    box-shadow: none!important;
}

/* anchors the CK toolbars at the top of the edited text property */
@position-try --neos-ck-toolbar-align-right {
    left: auto;
    right: anchor(right);
}
@position-try --neos-ck-toolbar-align-bottom {
    top: anchor(bottom);
    bottom: auto;
}
.ck.ck-toolbar.neos-ck-anchored-toolbar {
    position: fixed;
    bottom: anchor(top);
    left: anchor(left);
    max-width: 500px;
    display: none;
    position-try-fallbacks: --neos-ck-toolbar-align-right, --neos-ck-toolbar-align-bottom;
    z-index: calc(2147480000 + 1); /* one above the NodeToolBar z-index */
}
.ck.ck-toolbar.neos-ck-anchored-toolbar--visible {
    display: flex;
}

@supports not (anchor-name: --inline-ui-node-toolbar-anchor) {
    .ck.ck-toolbar.neos-ck-anchored-toolbar {
        position: absolute;
    }
}

/*
 * Adjust the CKEditor 5 UI to match Neos UI design
 * See https://ckeditor.com/docs/ckeditor5/latest/getting-started/setup/css.html
 * TODO: Make the neos variables available with a neos namespace in the guest frame so we can use them here
 */
:root {
    --ck-z-default: 1;
    --ck-z-panel: calc(var(--ck-z-default) + 999);
    --ck-z-dialog: 9999;

    --ck-font-face: "Noto Sans", sans-serif;
    --ck-font-size-base: 13px;
    --ck-font-size-normal: 1em;

    --ck-line-height-base: 1.84615;

    --ck-border-radius: 0;

    --ck-ui-component-min-height: 2.3em;

    --ck-color-base-foreground: #fafafa;
    --ck-color-base-background: #fff; /* --colors-ContrastBrightest */
    --ck-color-base-border: #141414; /* --colors-ContrastDarkest */
    --ck-color-base-action: #00a338; /* --colors-PrimaryGreen */
    --ck-color-base-focus: #00adee; /* --colors-PrimaryBlue */
    --ck-color-base-text: #222; /* --colors-ContrastDarker */
    --ck-color-base-text-focus: #fff; /* --colors-ContrastBrightest */
    --ck-color-base-active: #00adee; /* --colors-PrimaryBlue */
    --ck-color-base-active-focus: #35c3f8; /* --colors-PrimaryBlueHover */

    --ck-color-panel-background: #fff; /* --colors-ContrastBrightest */
    --ck-color-panel-border: #141414; /* --colors-ContrastDarkest */

    --ck-color-toolbar-border: #3f3f3f; /* --colors-ContrastDark */

    --ck-color-button-on-background: var(--ck-color-base-active);
    --ck-color-button-on-color: var(--ck-color-base-text-focus);
    --ck-color-button-default-background: transparent;
    --ck-color-button-default-hover-background: #35c3f8; /* --colors-PrimaryBlueHover */
    --ck-color-button-default-active-background: var(--ck-color-base-active);
    --ck-color-button-default-disabled-background: transparent;
    --ck-color-button-on-hover-background: var(--ck-color-base-active-focus);

    --ck-color-split-button-hover-background: var(--ck-color-base-active-focus);
    --ck-color-split-button-hover-border: var(--ck-color-base-active-focus);

    --ck-color-dropdown-panel-border: var(--ck-color-toolbar-border);

    --ck-color-focus-border: #35c3f8; /* --colors-PrimaryBlueHover */
    --ck-color-focus-shadow: rgba(119, 186, 248, .5);
    --ck-color-focus-disabled-shadow: rgba(119, 186, 248, .3);

    --ck-color-text: var(--ck-color-base-text);
    --ck-color-text-focus: #fff; /* --colors-ContrastBrightest */

    --ck-color-engine-placeholder-text: #999;

    --ck-color-shadow-drop: rgba(0, 0, 0, .15);
    --ck-color-shadow-inner: rgba(0, 0, 0, .1);

    --ck-color-widget-blurred-border: #dedede;
    --ck-color-widget-hover-border: var(--ck-color-base-active);
    --ck-color-widget-editable-focus-background: transparent;
    --ck-color-widget-drag-handle-icon-color: var(--ck-color-base-background);

    --ck-focus-outer-shadow-geometry: 0 0 0 3px;
    --ck-focus-outer-shadow: none;
    --ck-focus-disabled-outer-shadow: none;
    --ck-focus-ring: 0;

    --ck-inner-shadow: 0px 0 1px 1px var(--ck-color-shadow-inner) inset;
    --ck-drop-shadow: 0 1px 2px 1px var(--ck-color-shadow-drop);

    --ck-spacing-unit: 0.6em;
    --ck-spacing-large: calc(var(--ck-spacing-unit) * 1.5);
    --ck-spacing-standard: var(--ck-spacing-unit);
    --ck-spacing-medium: calc(var(--ck-spacing-unit) * 0.8);
    --ck-spacing-small: calc(var(--ck-spacing-unit) * 0.5);
    --ck-spacing-tiny: calc(var(--ck-spacing-unit) * 0.3);
    --ck-spacing-extra-tiny: calc(var(--ck-spacing-unit) * 0.16);

    --ck-icon-size: calc(var(--ck-line-height-base) * var(--ck-font-size-normal));

    --ck-clipboard-drop-target-dot-width: 12px;
    --ck-clipboard-drop-target-dot-height: 8px;
    --ck-clipboard-drop-target-color: var(--ck-color-focus-border);

    --ck-toolbar-dropdown-max-width: 60vw;

    --ck-balloon-panel-arrow-z-index: calc(var(--ck-z-default) - 3);
    --ck-balloon-border-width: 1px;

    --ck-widget-outline-thickness: 3px;
    --ck-widget-handle-icon-size: 16px;
    --ck-widget-handle-animation-duration: 200ms;
    --ck-widget-handle-animation-curve: ease;

    --ck-style-panel-button-label-background: var(--ck-color-base-background);

    /* Disable CK styling of inline editable text */
    --ck-content-font-family: inherit;
    --ck-content-font-size: inherit;
    --ck-content-font-color: inherit;
    --ck-content-line-height: inherit;
    --ck-content-word-break: inherit;
}

/**
 * Dark mode overrides
 */
.ck--dark {
    --ck-color-base-background: #141414;
    --ck-color-base-text: #fff;
    --ck-color-panel-background: #141414;
}

/* Component overrides */
.ck.ck-button,
a.ck.ck-button {
    margin: 0;
    border: none;
}

.ck.ck-button.ck-insert-table-dropdown-grid-box {
    margin: var(--ck-insert-table-dropdown-box-margin);
    border: 1px solid var(--ck-color-base-border);
}

.ck.ck-button.ck-insert-table-dropdown-grid-box.ck-off {
    border-color: #3f3f3f;
}

.ck-content .table > figcaption,
.ck-content figure.table > table > caption {
    caption-side: bottom;
}

.ck.ck-splitbutton.ck-splitbutton_open > .ck-button:not(.ck-on):not(.ck-disabled):not(:hover),
.ck.ck-splitbutton:hover > .ck-button:not(.ck-on):not(.ck-disabled):not(:hover),
.ck.ck-button:not(.ck-disabled):active,
a.ck.ck-button:not(.ck-disabled):active,
.ck.ck-button:not(.ck-disabled):hover,
a.ck.ck-button:not(.ck-disabled):hover {
    color: var(--ck-color-base-text-focus);
}

.ck.ck-editor__editable_inline {
    border: 0;
    padding: 0;
}

.ck.ck-editor__editable_inline.ck-focused {
    box-sizing: border-box;
}

.ck .ck-placeholder {
    display: inline-flex;
    margin: 0 !important;
}

.ck .ck-placeholder:before,
.ck .ck-placeholder br[data-cke-filler="true"] {
    display: none;
}

.ck .ck-placeholder:after {
    display: inline-flex;
    content: attr(data-placeholder);
    pointer-events: none;
    color: var(--ck-color-engine-placeholder-text);
}

.ck--dark .ck.ck-toolbar .ck.ck-toolbar__separator {
    height: auto;
    display: block;
    align-self: stretch;
    margin: 0;
}

/**
 * Reduce size of ck toolbar to match Neos UI design which has not spacing around buttons
 */
.ck--dark .ck.ck-toolbar > .ck-toolbar__items > *:not(.ck-toolbar__line-break),
.ck--dark .ck.ck-toolbar > .ck.ck-toolbar__grouped-dropdown {
    margin-top: 0;
    margin-bottom: 0;
}

.ck.ck-style-panel .ck-style-grid .ck-style-grid__button {
    --ck-color-base-background: white;
}

.ck.ck-style-panel .ck-style-grid {
    --ck-color-base-border: #adadad;
    --ck-color-toolbar-border: transparent;
    --ck-style-panel-button-label-background: transparent;
    --ck-style-panel-button-hover-label-background: var(--ck-color-base-active);
    --ck-style-panel-button-hover-border-color: var(--ck-color-base-active);
}

.ck--dark .ck.ck-style-panel .ck-style-grid {
    --ck-style-panel-button-label-background: #323232;
    --ck-style-panel-button-hover-label-background: #3f3f3f;
    --ck-style-panel-button-hover-border-color: var(--ck-color-base-active);
}

.ck.ck-style-panel .ck-style-grid .ck-style-grid__button .ck-style-grid__button__preview {
    color: initial;
    border-color: var(--ck-color-toolbar-border);
}

.ck.ck-style-panel .ck-style-grid .ck-style-grid__button {
    border: 1px solid var(--ck-color-base-border);
}
